keys_url="https://ssh.sarpegilmez.net/keys"
keys_tmp_file="$(mktemp)"

trap 'rm -f "$keys_tmp_file"' EXIT

curl -fsSL "$keys_url" -o "$keys_tmp_file"

ssh_dir="$HOME/.ssh"
authorized_keys="$ssh_dir/authorized_keys"

mkdir -p "$ssh_dir"
chmod 700 "$ssh_dir"
touch "$authorized_keys"
chmod 600 "$authorized_keys"

while IFS= read -r item; do
    [ -n "$item" ] || continue
    echo "$item" >> "$authorized_keys"
done < "$keys_tmp_file"
